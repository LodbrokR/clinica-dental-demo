---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Reservas">
    <section class="pt-32 pb-24 bg-slate-50">
        <div class="max-w-3xl mx-auto px-6">
            <div class="bg-white p-8 md:p-12 rounded-3xl shadow-xl shadow-slate-200/50 border border-slate-100">
                <h1 class="text-4xl font-bold text-slate-900 mb-2">Agenda tu hora</h1>
                <p class="text-slate-600 mb-8">Selecciona la especialidad y el horario que más te acomode. Tu primera evaluación es costo cero.</p>
                
                <form id="reservaForm" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">Especialidad</label>
                            <select name="Especialidad" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all outline-none">
                                <option>Evaluación General (Gratis)</option>
                                <option>Ortodoncia</option>
                                <option>Implantología</option>
                                <option>Odontopediatría</option>
                                <option>Urgencia</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">Sucursal</label>
                            <select name="Sucursal" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all outline-none">
                                <option>Providencia</option>
                                <option>Las Condes</option>
                                <option>Santiago Centro</option>
                            </select>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">Nombre completo</label>
                            <input name="Nombre" type="text" placeholder="Ej: Juan Pérez" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all outline-none" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">RUT</label>
                            <input name="RUT" type="text" placeholder="12.345.678-9" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all outline-none" required>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">Teléfono</label>
                            <input name="Telefono" type="tel" placeholder="+56 9 XXXX XXXX" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all outline-none" required>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-700 mb-2">Email</label>
                            <input name="Email" type="email" placeholder="correo@ejemplo.cl" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all outline-none" required>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-slate-700 mb-2">Previsión</label>
                        <select name="Prevision" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-brand-500 focus:border-transparent transition-all outline-none">
                            <option>Fonasa</option>
                            <option>Consalud</option>
                            <option>Colmena</option>
                            <option>Banmédica</option>
                            <option>CruzBlanca</option>
                            <option>Particular</option>
                        </select>
                    </div>

                    <button type="submit" id="submitBtn" class="w-full bg-brand-600 hover:bg-brand-500 text-white font-bold text-lg py-4 rounded-xl transition-all shadow-lg hover:shadow-xl mt-4">
                        Confirmar Reserva
                    </button>
                    <p id="formStatus" class="text-sm font-bold text-emerald-600 hidden text-center mt-2">¡Reserva enviada! Te contactaremos pronto.</p>
                    <p class="text-xs text-slate-500 text-center mt-4">Al confirmar, aceptas nuestros términos y condiciones de privacidad.</p>
                </form>
            </div>
        </div>
    </section>
</Layout>

<script>
	const form = document.getElementById('reservaForm') as HTMLFormElement;
	const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
	const formStatus = document.getElementById('formStatus');

	if (form) {
		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			
			const originalText = submitBtn.innerText;
			submitBtn.innerText = 'Enviando reserva...';
			submitBtn.disabled = true;

			try {
				const formData = new FormData(form);
				const res = await fetch('/api/send-email', {
					method: 'POST',
					body: formData
				});

				if (res.ok) {
					form.reset();
					formStatus?.classList.remove('hidden');
					setTimeout(() => {
						formStatus?.classList.add('hidden');
					}, 5000);
				} else {
					alert('Hubo un error al procesar tu reserva. Inténtalo nuevamente.');
				}
			} catch (error) {
				alert('Hubo un error de conexión.');
			} finally {
				submitBtn.innerText = originalText;
				submitBtn.disabled = false;
			}
		});
	}
</script>
