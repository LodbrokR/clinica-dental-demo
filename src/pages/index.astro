---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Inicio">
	<!-- Hero Section -->
	<section class="relative pt-12 pb-24 lg:pt-24 lg:pb-32 overflow-hidden">
		<div class="absolute inset-0 bg-gradient-to-br from-brand-50 to-white -z-10"></div>
		<!-- Deco blob -->
		<div class="absolute top-0 right-0 -translate-y-12 translate-x-1/3 w-[800px] h-[800px] bg-brand-100/50 rounded-full blur-3xl -z-10"></div>
		
		<div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center">
			<div class="max-w-2xl">
				<div class="inline-block px-4 py-1.5 rounded-full bg-brand-100 text-brand-600 font-semibold text-sm mb-6 border border-brand-200">
					✨ Tu nueva sonrisa empieza aquí
				</div>
				<h1 class="text-5xl lg:text-7xl font-bold tracking-tight text-slate-900 mb-6 leading-tight">
					Odontología de <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-600 to-blue-400">nivel mundial</span> en Chile.
				</h1>
				<p class="text-lg text-slate-600 mb-8 leading-relaxed">
					Diseñamos sonrisas perfectas con tecnología 3D y especialistas dedicados. Agenda tu evaluación sin costo y descubre el poder de una sonrisa sana.
				</p>
				<div class="flex flex-col sm:flex-row gap-4">
					<a href="/reservas" class="bg-brand-600 hover:bg-brand-500 text-white px-8 py-4 rounded-full font-semibold text-lg transition-all shadow-xl shadow-brand-500/20 hover:shadow-2xl hover:-translate-y-1 text-center">
						Agendar Evaluación
					</a>
					<a href="#servicios" class="bg-white hover:bg-slate-50 text-slate-800 px-8 py-4 rounded-full font-semibold text-lg transition-all border border-slate-200 text-center">
						Ver Tratamientos
					</a>
				</div>
				
				<div class="mt-12 flex items-center gap-4">
					<div class="flex -space-x-3">
						<!-- Stock avatars from unsplash or generic -->
						<img src="https://i.pravatar.cc/100?img=1" class="w-10 h-10 rounded-full border-2 border-white shadow-sm" alt="Paciente" />
						<img src="https://i.pravatar.cc/100?img=2" class="w-10 h-10 rounded-full border-2 border-white shadow-sm" alt="Paciente" />
						<img src="https://i.pravatar.cc/100?img=3" class="w-10 h-10 rounded-full border-2 border-white shadow-sm" alt="Paciente" />
					</div>
					<div class="text-sm">
						<p class="font-bold text-slate-900">+2.500 pacientes</p>
						<p class="text-slate-500">Nos recomiendan en Santiago</p>
					</div>
				</div>
			</div>
			<div class="relative lg:h-[600px] flex items-center justify-center">
				<!-- Placeholder for Banana Image -->
				<div class="w-full h-full min-h-[400px] bg-slate-200 rounded-3xl overflow-hidden shadow-2xl shadow-brand-900/10 relative">
					<div class="absolute inset-0 bg-gradient-to-t from-slate-900/40 to-transparent"></div>
					<div class="absolute bottom-6 left-6 right-6 bg-white/90 backdrop-blur-md p-4 rounded-2xl flex items-center gap-4 shadow-lg">
						<div class="w-12 h-12 bg-green-100 text-green-600 rounded-xl flex items-center justify-center">
							<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
						</div>
						<div>
							<p class="font-bold text-slate-900">Atención 100% Sin Dolor</p>
							<p class="text-sm text-slate-500">Tecnología de anestesia digital</p>
						</div>
					</div>
					<!-- TO DO: REPLACE WITH BANANA IMAGE -->
					<div class="w-full h-full flex items-center justify-center text-slate-400 bg-brand-50">
						[Imagen Hero Banana: dentista_moderno.jpg]
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Bento Grid Services Section -->
	<section id="servicios" class="py-24 bg-white">
		<div class="max-w-7xl mx-auto px-6">
			<div class="text-center mb-16">
				<h2 class="text-4xl font-bold text-slate-900 mb-4">Tratamientos de Vanguardia</h2>
				<p class="text-lg text-slate-600 max-w-2xl mx-auto">Soluciones integrales para la salud y estética de tu sonrisa, en un solo lugar.</p>
			</div>

			<!-- Bento Layout -->
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6 auto-rows-[250px]">
				<!-- Large Item -->
				<a href="/servicios" class="md:col-span-2 md:row-span-2 group relative rounded-3xl overflow-hidden bg-slate-100 flex items-end p-8 shadow-sm hover:shadow-xl transition-all duration-500 border border-slate-200/50">
					<div class="absolute inset-0 bg-brand-500/10 group-hover:bg-brand-500/20 transition-colors z-0"></div>
					<!-- Image placeholder -->
					<div class="absolute inset-0 flex items-center justify-center text-slate-400 z-0">
						[Imagen Banana: ortodoncia_invisible.jpg]
					</div>
					<div class="relative z-10 bg-white/90 backdrop-blur-md p-6 rounded-2xl max-w-sm w-full transform group-hover:-translate-y-2 transition-transform duration-500 shadow-lg">
						<h3 class="text-2xl font-bold text-slate-900 mb-2">Ortodoncia Invisible</h3>
						<p class="text-slate-600 mb-4">Alineadores transparentes 3D. Cómodos, rápidos y estéticos.</p>
						<span class="text-brand-600 font-semibold flex items-center gap-2">Ver tratamiento <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg></span>
					</div>
				</a>

				<!-- Small Item 1 -->
				<a href="/servicios" class="group relative rounded-3xl overflow-hidden bg-slate-100 p-6 flex flex-col justify-end shadow-sm hover:shadow-xl transition-all border border-slate-200/50">
					<!-- Image placeholder -->
					<div class="absolute inset-0 flex items-center justify-center text-slate-400 z-0 bg-blue-50">
						[Imagen Banana: implantes.jpg]
					</div>
					<div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-slate-900/20 to-transparent z-0"></div>
					<div class="relative z-10">
						<h3 class="text-xl font-bold text-white mb-1">Implantología</h3>
						<p class="text-slate-300 text-sm">Recupera tu sonrisa en 24h.</p>
					</div>
				</a>

				<!-- Small Item 2 -->
				<a href="/servicios" class="group relative rounded-3xl overflow-hidden bg-slate-100 p-6 flex flex-col justify-end shadow-sm hover:shadow-xl transition-all border border-slate-200/50">
					<!-- Image placeholder -->
					<div class="absolute inset-0 flex items-center justify-center text-slate-400 z-0 bg-indigo-50">
						[Imagen Banana: blanqueamiento.jpg]
					</div>
					<div class="absolute inset-0 bg-gradient-to-t from-slate-900/80 via-slate-900/20 to-transparent z-0"></div>
					<div class="relative z-10">
						<h3 class="text-xl font-bold text-white mb-1">Estética Dental</h3>
						<p class="text-slate-300 text-sm">Carillas y blanqueamiento LED.</p>
					</div>
				</a>

				<!-- Horizontal Item -->
				<div class="md:col-span-3 rounded-3xl bg-brand-600 p-8 md:p-12 text-white flex flex-col md:flex-row items-center justify-between shadow-xl shadow-brand-500/20 relative overflow-hidden">
					<div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-white to-transparent"></div>
					<div class="relative z-10 md:w-2/3 mb-6 md:mb-0">
						<h3 class="text-3xl font-bold mb-2">¿Dolor de muelas? ¡No esperes!</h3>
						<p class="text-brand-100 text-lg">Servicio de Urgencias 24/7 en todas nuestras sucursales. Atención inmediata.</p>
					</div>
					<a href="tel:+56900000000" class="relative z-10 bg-white text-brand-600 px-8 py-4 rounded-full font-bold text-lg hover:scale-105 transition-transform shadow-lg whitespace-nowrap">
						Llamar Urgencia
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Seguros Section -->
	<section class="py-16 bg-slate-50 border-y border-slate-200">
		<div class="max-w-7xl mx-auto px-6 text-center">
			<p class="text-sm font-bold text-slate-400 uppercase tracking-wider mb-8">Atendemos con tu seguro o isapre</p>
			<div class="flex flex-wrap justify-center items-center gap-8 md:gap-16 opacity-60 grayscale">
				<div class="text-xl font-black">Consalud</div>
				<div class="text-xl font-black">Banmédica</div>
				<div class="text-xl font-black">Colmena</div>
				<div class="text-xl font-black">CruzBlanca</div>
				<div class="text-xl font-black">Fonasa</div>
			</div>
		</div>
	</section>
</Layout>
